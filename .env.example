# Local environment template

# 0G Galileo testnet
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_UPLOAD_TIMEOUT_MS=300000
OG_STORAGE_MEMORY_LAYOUT=compact
OG_COMPUTE_PROVIDER_ADDRESS=
OG_PRIVATE_KEY=

# Sepolia testnet for KeeperHub-supported pass issuance
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_PRIVATE_KEY=

# Reclaim / zkTLS proof generation
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
# Optional pinned attestor. Leave empty to discover from Reclaim feature flags.
RECLAIM_ATTESTOR_URL=
RECLAIM_PROOF_TIMEOUT_MS=180000

# KeeperHub Direct Execution API
KH_API_KEY=
KH_API_BASE_URL=https://app.keeperhub.com
KH_NETWORK=sepolia
KH_DEPLOYMENT_PATH=deployments/sepolia/addresses.json
KH_FETCH_RETRIES=3
KH_FETCH_RETRY_INTERVAL_MS=5000
KH_FETCH_TIMEOUT_MS=60000

# Never commit real secrets.
